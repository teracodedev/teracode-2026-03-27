generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FamilyRegister {
  id           String       @id @default(uuid())
  registerCode String       @unique @default(uuid())
  name         String
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  householders Householder?
}

model Householder {
  familyName       String
  givenName        String
  familyNameKana   String?
  givenNameKana    String?
  postalCode       String?
  email            String?
  note             String?
  joinedAt         DateTime?
  leftAt           DateTime?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  id               String                @id @default(uuid())
  householderCode  String                @unique @default(uuid())
  address1         String?
  address2         String?
  address3         String?
  phone1           String?
  phone2           String?
  domicile         String?
  fax              String?
  gender           String?
  birthDate        DateTime?
  deathDate        DateTime?
  ageAtDeath       String?
  dharmaName       String?
  dharmaNameKana   String?
  relation         String?
  familyRegisterId String?               @unique
  ceremonies       CeremonyParticipant[]
  familyRegister   FamilyRegister?       @relation(fields: [familyRegisterId], references: [id])
  members          HouseholderMember[]
}

model HouseholderMember {
  relation          String?
  birthDate         DateTime?
  deathDate         DateTime?
  ageAtDeath        String?
  dharmaName        String?
  note              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  id                String      @id @default(uuid())
  householderId     String
  dharmaNameKana    String?
  familyName        String
  givenName         String?
  familyNameKana    String?
  givenNameKana     String?
  postalCode        String?
  address1          String?
  address2          String?
  address3          String?
  phone1            String?
  phone2            String?
  fax               String?
  domicile          String?
  gender            String?
  email             String?
  notePrintDisabled Boolean     @default(false)
  meinichiFusho     Boolean     @default(false)
  householder       Householder @relation(fields: [householderId], references: [id], onDelete: Cascade)
}

model Ceremony {
  title        String
  ceremonyType CeremonyType
  scheduledAt  DateTime
  endAt        DateTime?
  location     String?
  description  String?
  maxAttendees Int?
  fee          Int?
  status       CeremonyStatus        @default(SCHEDULED)
  note         String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  id           String                @id @default(uuid())
  participants CeremonyParticipant[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CeremonyParticipant {
  attendees     Int         @default(1)
  offering      Int?
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  id            String      @id @default(uuid())
  ceremonyId    String
  householderId String
  ceremony      Ceremony    @relation(fields: [ceremonyId], references: [id], onDelete: Cascade)
  householder   Householder @relation(fields: [householderId], references: [id], onDelete: Cascade)

  @@unique([ceremonyId, householderId])
}

enum CeremonyType {
  MEMORIAL
  REGULAR
  FUNERAL
  SPECIAL
  OTHER
}

enum CeremonyStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
