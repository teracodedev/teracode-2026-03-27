generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FamilyRegister {
  id           String       @id @default(uuid())
  registerCode String       @unique @default(uuid())
  name         String
  nameKana     String?
  note         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  householders Householder?
}

model Householder {
  familyName       String
  givenName        String
  familyNameKana   String?
  givenNameKana    String?
  postalCode       String?
  email            String?
  note             String?
  joinedAt         DateTime?
  leftAt           DateTime?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  id               String                @id @default(uuid())
  householderCode  String                @unique @default(uuid())
  address1         String?
  address2         String?
  address3         String?
  phone1           String?
  phone2           String?
  domicile         String?
  fax              String?
  gender           String?
  birthDate        DateTime?
  deathDate        DateTime?
  ageAtDeath       String?
  dharmaName       String?
  dharmaNameKana   String?
  relation         String?
  familyRegisterId String?               @unique
  familyRegister   FamilyRegister?       @relation(fields: [familyRegisterId], references: [id])
  members          HouseholderMember[]
  addressHistories HouseholderAddressHistory[]
  tags             HouseholderTag[]
  graveContracts   GraveContract[]
}

model HouseholderAddressHistory {
  id            String      @id @default(uuid())
  householderId String
  postalCode    String?
  address1      String?
  address2      String?
  address3      String?
  movedAt       DateTime    @default(now())
  note          String?
  householder   Householder @relation(fields: [householderId], references: [id], onDelete: Cascade)
}

model HouseholderMember {
  relation          String?
  birthDate         DateTime?
  deathDate         DateTime?
  ageAtDeath        String?
  dharmaName        String?
  note              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  id                String      @id @default(uuid())
  householderId     String
  dharmaNameKana    String?
  familyName        String
  givenName         String?
  familyNameKana    String?
  givenNameKana     String?
  postalCode        String?
  address1          String?
  address2          String?
  address3          String?
  phone1            String?
  phone2            String?
  fax               String?
  domicile          String?
  gender            String?
  email             String?
  notePrintDisabled Boolean     @default(false)
  meinichiFusho     Boolean     @default(false)
  householder       Householder @relation(fields: [householderId], references: [id], onDelete: Cascade)
  tags              MemberTag[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id             String           @id @default(uuid())
  name           String           @unique
  color          String           @default("#6b7280")
  createdAt      DateTime         @default(now())
  householderTags HouseholderTag[]
  memberTags     MemberTag[]
}

model HouseholderTag {
  id            String      @id @default(uuid())
  householderId String
  tagId         String
  householder   Householder @relation(fields: [householderId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([householderId, tagId])
}

model MemberTag {
  id       String            @id @default(uuid())
  memberId String
  tagId    String
  member   HouseholderMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tag      Tag               @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([memberId, tagId])
}

model GravePlot {
  id                String          @id @default(uuid())
  plotNumber         String          @unique
  area               Float?
  width              Float?
  depth              Float?
  permanentUsageFee  Int?
  managementFee      Int?
  note               String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  contracts          GraveContract[]
}

model GraveContract {
  id              String          @id @default(uuid())
  gravePlotId     String
  householderId   String
  startDate       DateTime?
  endDate         DateTime?
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  gravePlot       GravePlot       @relation(fields: [gravePlotId], references: [id], onDelete: Cascade)
  householder     Householder     @relation(fields: [householderId], references: [id], onDelete: Cascade)
  histories       GraveContractHistory[]
}

model GraveContractHistory {
  id              String        @id @default(uuid())
  graveContractId String
  householderName String
  householderKana String?
  startDate       DateTime?
  endDate         DateTime?
  transferredAt   DateTime      @default(now())
  note            String?
  graveContract   GraveContract @relation(fields: [graveContractId], references: [id], onDelete: Cascade)
}
